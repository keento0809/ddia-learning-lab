{
  "permissions": {
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run validate:content*)",
      "Bash(npm run dev*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push origin feat/*)",
      "Bash(git checkout -b feat/*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin main*)",
      "Bash(git branch -D main*)",
      "Bash(git reset --hard origin/main*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .*)",
      "Bash(npx prisma migrate reset*)",
      "Bash(npx prisma db push --force-reset*)",
      "Bash(wrangler delete*)",
      "Bash(gh repo delete*)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
