// Prisma schema — 02_詳細設計書.md §2.1 テーブル定義の物理化。
// マイグレーション方針は §2.2 (Prisma Migrateで管理)。

// compilerBuild = "small": Cloudflare Workers Freeプラン上限(3MiB gzip、ADR-007 C-1)
// に対しquery compiler WASM(driver adapter経由のclient engine)が最大の単体依存
// (esbuild metafile分析で4.86MiB)だったため、既定の"fast"から切替。
// API/クエリ機能に変更はなく(Prisma 7.3 changelogが明記するsize/perfトレードオフの
// ビルド差し替えのみ)、実行速度と引き換えにバンドルサイズを縮小する。
generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
  compilerBuild   = "small"
}

// 失敗→恒久対策(T-502): worker-api(workers/api/)はwrangler(esbuild)でバンドルされ
// Cloudflare Workers(workerd)上で実行される。既定(runtime未指定="nodejs"扱い)の
// 生成クライアントは`@prisma/client/runtime/client`をimportし、モジュール読み込み時に
// `globalThis['__dirname'] = path.dirname(fileURLToPath(import.meta.url))`を実行する。
// workerdでは`import.meta.url`が定義されないため、wrangler経由でバンドルしたWorkerは
// この行で`TypeError: The "path" argument must be of type string or an instance of URL.
// Received undefined`を起こしWorker起動自体に失敗する(workers/api/tests/でMiniflare
// 実行時に検出)。Prismaの生成器は`runtime`設定で対象ランタイムを切り替えられ、
// "workerd"を指定すると`@prisma/client/runtime/wasm-compiler-edge`(import.meta.urlに
// 依存しない、WASM本体をCompiledWasmモジュールとしてimportする版)が使われる。
//
// 上記の既定generator(client)にruntime="workerd"を直接指定すると、今度は`next build`
// (webpack、Node向け)側が同じ理由の逆方向で壊れる: webpackは`?module`サフィックス付き
// wasmインポートをCloudflare Workers専用の規約として解釈できず
// "Module parse failed"でビルド失敗する。worker-appは現時点でもlib/db.ts(Auth.js
// アダプタ経由)を通じてPrismaを使っており(ADR-008 §2「worker-appからPrisma依存を
// 完全除去」はT-503のスコープ)、next build自体はNode向けクライアントを要求し続ける。
// そのため生成器を2本立てにし、worker-api専用に別出力先へworkerd向けクライアントを
// 生成する(workers/api/src/db.tsが専用にimportする。lib/db.ts・Next.js側は既定の
// generator clientの出力を使い続けるため無関係)。
generator clientWorkerd {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma-workerd"
  previewFeatures = ["postgresqlExtensions"]
  compilerBuild   = "small"
  runtime         = "workerd"
}

// Prisma 7: 接続URLはschema.prismaではなくprisma.config.ts/PrismaClientの
// adapterで指定する(P1012)。ここではprovider/extensionsのみ宣言する。
datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

/// 02 §2.1 users
model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.Citext
  passwordHash String?   @map("password_hash")
  displayName  String    @map("display_name") @db.VarChar(50)
  localePref   String    @default("ja") @map("locale_pref") @db.VarChar(5)
  themePref    String    @default("system") @map("theme_pref") @db.VarChar(10)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  oauthAccounts OauthAccount[]
  progress      Progress[]
  submissions   Submission[]
  notes         Note[]
  userBadges    UserBadge[]
  streak        Streak?

  @@map("users")
}

/// 02 §2.1 oauth_accounts
model OauthAccount {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String @map("user_id") @db.Uuid
  provider          String @db.VarChar(20)
  providerAccountId String @map("provider_account_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

/// 02 §2.1 progress
model Progress {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  itemType    String    @map("item_type") @db.VarChar(10)
  itemSlug    String    @map("item_slug") @db.VarChar(120)
  status      String    @db.VarChar(15)
  score       Int?      @db.SmallInt
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, itemType, itemSlug])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("progress")
}

/// 02 §2.1 submissions
model Submission {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  exerciseSlug        String   @map("exercise_slug") @db.VarChar(120)
  language            String   @db.VarChar(10)
  code                String
  result              String   @db.VarChar(10)
  passedTests         Int      @map("passed_tests") @db.SmallInt
  totalTests          Int      @map("total_tests") @db.SmallInt
  durationMs          Int?     @map("duration_ms")
  clientGraderVersion String   @map("client_grader_version") @db.VarChar(20)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId, exerciseSlug, createdAt(sort: Desc)])
  @@map("submissions")
}

/// 02 §2.1 notes
model Note {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  lessonSlug String   @map("lesson_slug") @db.VarChar(120)
  bodyMd     String   @map("body_md")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, lessonSlug])
  @@map("notes")
}

/// 02 §2.1 badges
model Badge {
  id       Int    @id @default(autoincrement()) @db.SmallInt
  slug     String @unique @db.VarChar(50)
  criteria Json

  userBadges UserBadge[]

  @@map("badges")
}

/// 02 §2.1 user_badges
model UserBadge {
  userId    String   @map("user_id") @db.Uuid
  badgeId   Int      @map("badge_id") @db.SmallInt
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
  @@map("user_badges")
}

/// 02 §2.1 streaks(学習ストリーク)
model Streak {
  userId         String    @id @map("user_id") @db.Uuid
  currentDays    Int       @default(0) @map("current_days")
  longestDays    Int       @default(0) @map("longest_days")
  lastActiveDate DateTime? @map("last_active_date") @db.Date

  user User @relation(fields: [userId], references: [id])

  @@map("streaks")
}
